# Frontend Environment Variables
VITE_API_URL=https://verifyid.vercel.app/api
VITE_FACE_VERIFICATION_URL=https://your-face-verification-service.herokuapp.com
VITE_PAYMENT_GATEWAY_URL=https://your-payment-gateway.herokuapp.com

# Backend Environment Variables
DATABASE_URL=./database.sqlite
JWT_SECRET=your-jwt-secret-key-change-this
NODE_ENV=production

# Face Verification Service
DEEPFACE_MODEL=Facenet
LIVENESS_THRESHOLD=0.5
COSINE_SIMILARITY_THRESHOLD=0.80

# Payment Gateway
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLIC_KEY=pk_test_your_key
